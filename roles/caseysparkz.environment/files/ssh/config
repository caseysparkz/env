# WAN
Host git
    User                    git
    Hostname                github.com

# Catchall
Host *
    AddKeysToAgent          yes
    CanonicalizeHostname    yes
    CheckHostIP             yes
    ConnectTimeout          5
    ForwardAgent            no
    ForwardX11              no
    IdentitiesOnly          yes
    PubkeyAcceptedKeyTypes  +ssh-rsa
    ServerAliveCountMax     120
    ServerAliveInterval     5
    #ControlMaster           auto
    #ControlPath             ~/.ssh/control_paths/master-%u-%C
    #ControlPersist          72h
    #IPQoS=throughput
    #LogLevel                QUIET
    #StrictHostKeyChecking   no
